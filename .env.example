# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here

# Vertex AI Embeddings
VERTEX_AI_PROJECT_ID=your_gcp_project_id

# Facebook Messenger
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_PAGE_ACCESS_TOKEN=your_page_access_token

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# Admin Bootstrap
ADMIN_BOOTSTRAP_PASSWORD=your_admin_password

# Support
SUPPORT_DEFAULT_MANAGER_EMAIL=admin@example.com
SUPPORT_TOKEN_SECRET=your_token_secret

# Email
EMAIL_HOST=smtp.example.com
EMAIL_USERNAME=your_email_username
EMAIL_PASSWORD=your_email_password
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_BASE_URL=https://your-domain.com

# Nobita API
NOBITA_API_KEY=your_nobita_api_key

RUN_LIVE_AI_RAG_TESTS=false

VERTEX_AI_SERVICE_ACCOUNT_KEY_PATH=vertex_ai_service_account_key_path

# Seq Log Aggregation (use __ for ASP.NET Core config section mapping)
Seq__ApiKey=your_seq_api_key_here

# Telegram Notifications
Telegram__BotToken=your_telegram_bot_token_here

# Internal Alerts API
Alerts__InternalApiKey=your_internal_api_key_here