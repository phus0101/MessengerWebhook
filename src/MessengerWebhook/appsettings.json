{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=messenger_bot;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "MessengerWebhook": "Information",
      "MessengerWebhook.BackgroundServices": "Information",
      "MessengerWebhook.Services": "Information"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss ",
        "UseUtcTimestamp": true,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "AllowedHosts": "*",
  "Webhook": {
    "VerifyToken": "",
    "TimeoutSeconds": 30,
    "MaxRetries": 3,
    "RetryDelaySeconds": 5,
    "ChannelCapacity": 1000
  },
  "Facebook": {
    "AppSecret": "",
    "PageAccessToken": "",
    "ApiVersion": "v25.0",
    "GraphApiBaseUrl": "https://graph.facebook.com"
  },
  "Gemini": {
    "ApiKey": "",
    "ProModel": "gemini-2.5-flash-lite",
    "FlashLiteModel": "gemini-2.5-flash-lite",
    "EmbeddingModel": "gemini-embedding-2-preview",
    "MaxTokens": 2048,
    "Temperature": 0.7,
    "MaxRetries": 3,
    "TimeoutSeconds": 60,
    "AiDetectionTimeoutMs": 500,
    "SystemPromptPath": "Prompts/sales-closer-system-prompt.txt",
    "EnableAiConfirmationDetection": true,
    "ConfirmationConfidenceThreshold": 0.7,
    "ConfirmationCacheTtlMinutes": 5,
    "EnableAiIntentDetection": true,
    "IntentConfidenceThreshold": 0.7,
    "RateLimits": {
      "RequestsPerMinute": 60,
      "TokensPerMinute": 100000
    }
  },
  "Nobita": {
    "BaseUrl": "https://testing.ecrm.vn/public-api/v1/",
    "ApiKey": "",
    "EnableCustomerInsightLookup": false,
    "EnableDirectOrderSubmission": true,
    "TimeoutSeconds": 30
  },
  "Support": {
    "DefaultManagerEmail": "",
    "BotLockTimeoutMinutes": 120,
    "ResumeBotOnNextMessage": true,
    "TokenExpirationDays": 7,
    "TokenSecret": ""
  },
  "Admin": {
    "CookieName": "messenger_admin",
    "LoginPath": "/admin/login",
    "BootstrapEmail": "",
    "BootstrapPassword": "",
    "BootstrapFullName": "Admin"
  },
  "Email": {
    "Host": "",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "Messenger Sales Bot",
    "EnableSsl": true,
    "BaseUrl": "",
    "EnableHtmlEmails": true
  },
  "VertexAI": {
    "ProjectId": "",
    "Location": "asia-southeast1",
    "Model": "text-embedding-004",
    "ServiceAccountKeyPath": "./vertex-ai-key.json",
    "TimeoutSeconds": 30,
    "MaxRetries": 3
  },
  "Pinecone": {
    "ApiKey": "",
    "Environment": "us-east-1",
    "IndexName": "messenger-bot-products",
    "TimeoutSeconds": 10
  },
  "PolicyGuard": {
    "EscalationKeywords": [],
    "SafeReplyMessage": "Chị iu ơi, phần này em chưa thể xác nhận ngay trong chat. Nếu chị muốn, em sẽ chuyển chị qua bạn hỗ trợ của Mũi Xù để kiểm tra kỹ hơn nha.",
    "EnableRegexDetector": true,
    "EnableFuzzyDetector": true,
    "EnableSemanticClassifier": false,
    "SemanticClassifierMinConfidence": 0.85,
    "SafeReplyThreshold": 0.35,
    "SoftEscalateThreshold": 0.6,
    "HardEscalateThreshold": 0.8,
    "RepeatMentionBoost": 0.1,
    "OpenSupportCaseBoost": 0.15,
    "DraftOrderBoost": 0.05,
    "MaxRecentTurns": 5,
    "ClassifierTimeoutMs": 1200
  },
  "SalesBot": {
    "ClosingCallToAction": "Chị iu cho em xin số điện thoại và địa chỉ em lên đơn luôn nha.",
    "VipOrderThreshold": 3,
    "HighRiskThreshold": 0.5,
    "IntentConfidenceThreshold": 0.7,
    "MaxConsultationAttempts": 2,
    "ConversationHistoryLimit": 15,
    "UnsupportedFallbackMessage": "Dạ em xin phép chuyển chị qua bạn hỗ trợ của Múi Xù để xử lý kỹ hơn nha."
  },
  "LiveComment": {
    "Enabled": true,
    "AutoHideComments": true,
    "TriggerKeywords": ["mua", "đặt hàng", "order", "kcn", "kem lụa"],
    "WelcomeMessage": "Dạ em chào chị! Em thấy chị quan tâm sản phẩm của Múi Xù ạ.\n\nEm đã nhắn tin riêng cho chị để tư vấn chi tiết hơn nha. Chị check tin nhắn giúp em ạ 💕",
    "MaxCommentsPerMinute": 50,
    "ProcessReplaysOnly": false
  },
  "RRF": {
    "K": 60
  },
  "RAG": {
    "Enabled": true,
    "TopK": 5,
    "FallbackStrategy": "full-context",
    "TimeoutMs": 5000
  },
  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "messenger-rag:",
    "Enabled": true
  },
  "CacheTTL": {
    "EmbeddingSeconds": 3600,
    "ResultSeconds": 900,
    "ResponseSeconds": 300
  },
  "EmotionDetection": {
    "EnableContextAnalysis": true,
    "ContextWindowSize": 3,
    "ConfidenceThreshold": 0.6,
    "EnableCaching": true,
    "CacheDurationMinutes": 5
  },
  "ToneMatching": {
    "EnableEmotionBasedAdaptation": true,
    "EnableEscalationDetection": true,
    "FrustrationEscalationThreshold": 0.7,
    "DefaultPronoun": "bạn",
    "EnableCaching": true,
    "CacheDurationMinutes": 5
  },
  "ConversationAnalysis": {
    "AnalysisWindowSize": 10,
    "EnablePatternDetection": true,
    "EnableTopicAnalysis": true,
    "EnableInsightGeneration": true,
    "BuyingSignalThreshold": 0.7,
    "RepeatQuestionThreshold": 0.8,
    "RepeatQuestionWindow": 5,
    "EnableCaching": true,
    "CacheDurationMinutes": 10
  },
  "SmallTalk": {
    "EnableSmallTalkDetection": true,
    "EnableContextAwareGreetings": true,
    "SmallTalkConfidenceThreshold": 0.7,
    "MaxSmallTalkTurns": 3,
    "EnableSoftTransitions": true
  },
  "ResponseValidation": {
    "EnableValidation": true,
    "EnableToneValidation": true,
    "EnableContextValidation": true,
    "EnableLanguageValidation": true,
    "EnableStructureValidation": true,
    "MinResponseLength": 10,
    "MaxResponseLength": 500,
    "BlockOnErrors": false
  },
  "ABTesting": {
    "Enabled": false,
    "TreatmentPercentage": 50,
    "HashSeed": "ab-test-2026"
  },
  "Metrics": {
    "BatchSize": 100,
    "FlushIntervalSeconds": 60,
    "Enabled": true
  },
  "CSATSurvey": {
    "Enabled": true,
    "DelayMinutes": 5,
    "SendFollowUpForLowRatings": true,
    "LowRatingThreshold": 3,
    "Messages": {
      "SurveyQuestion": "Bạn đánh giá trải nghiệm tư vấn như thế nào?",
      "FollowUpQuestion": "Bạn có thể chia sẻ thêm để chúng em cải thiện không?",
      "ThankYou": "Cảm ơn bạn đã đánh giá! Ý kiến của bạn giúp chúng em cải thiện dịch vụ."
    }
  },
  "SubIntent": {
    "ClassifierTimeoutMs": 500,
    "MinConfidence": 0.5,
    "KeywordHighConfidenceThreshold": 0.9,
    "HybridAiAcceptanceThreshold": 0.7,
    "EnableAiFallback": true
  }
}
